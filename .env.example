# Helius RPC API key — get one at https://dashboard.helius.dev
# Copy this file to .env.local and set your key. .env.local is gitignored.
#
# IMPORTANT: this is a client-side app, so the key is exposed in the deployed
# bundle and network requests. Restrict the key to your site's origin in the
# Helius dashboard so it cannot be reused elsewhere.
#
# If unset, the app falls back to the public cluster RPC (rate-limited).
VITE_HELIUS_API_KEY=your-helius-api-key-here
